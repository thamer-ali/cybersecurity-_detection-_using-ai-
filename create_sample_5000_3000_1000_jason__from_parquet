# ============================================================
# UGR16 → Suspect Selection → Sampling → JSONL + Report
# Production / Research-Quality Version 7
#
# Changes in v7:
#  18. Step 1 split into three sub-steps:
#      1a. toDF() — renames positional/_c0 columns to semantic
#          names immediately after spark.read.parquet()
#      1b. .select() with explicit casts — runs before suspect
#          filter so dst_port.isin(), total_pkts >, total_bytes >
#          comparisons work correctly on typed columns
#      1c. schema validation — unchanged, now runs after rename
#          and cast so column names are guaranteed clean
#  19. total_pkts and total_bytes cast to long (bigint) not int.
#      int overflows at 2,147,483,647 bytes — UGR16 long-duration
#      flows can exceed this, producing silent wrong comparisons.
# ============================================================

import os
import glob
import shutil
import time
import json
from datetime import datetime

from pyspark.sql import SparkSession
from pyspark.sql.functions import (
    col,
    when,
    lit,
    rand,
    row_number,
    sha2,
    concat_ws,
    to_json,
    struct,
    array,
    array_remove,
    array_join,
    coalesce,
    count as spark_count
)
from pyspark.sql.window import Window


# ============================================================
# Paths — edit these for your cluster
# ============================================================

INPUT_PATH  = "/data/parquet"
OUTPUT_BASE = "/data/llm_samples"

os.makedirs(OUTPUT_BASE, exist_ok=True)


# ============================================================
# Constants
# ============================================================
#
# ── How to run on Azure (8 CPU / 64 GB / 1.8 TB) ────────────
#
#   Memory settings inside SparkSession.builder are IGNORED by
#   spark-submit — the JVM is already started before Python runs.
